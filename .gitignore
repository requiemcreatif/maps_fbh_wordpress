# WordPress core (recommended to keep WP core out of git)
/wp-admin/
/wp-includes/
/wp-content/index.php
/wp-*.php
/xmlrpc.php
/index.php
/license.txt
/readme.html

# WordPress config (site-specific secrets)
/wp-config.php
/.htpasswd
/.well-known/

# Uploads (environment-specific content)
/wp-content/uploads/

# Upgrade/temp
/wp-content/upgrade/
/wp-content/backup*/
/wp-content/backups/

# Cache (common plugins)
/wp-content/cache/
/wp-content/ai1wm-backups/
/wp-content/updraft/
/wp-content/wflogs/
/wp-content/wp-rocket-config/
/wp-content/et-cache/
/wp-content/litespeed/
/wp-content/debug.log

# Languages (generated)
/wp-content/languages/

# Must-use plugins (often site-specific)
/wp-content/mu-plugins/

# Node / build artifacts (common in modern themes/plugins)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.parcel-cache/
.next/
dist/
build/
.turbo/
.vite/

# Composer / PHP deps (only ignore if you vendor dependencies)
vendor/

# Logs
*.log

# OS junk
.DS_Store
Thumbs.db

# IDE/editor junk
.idea/
.vscode/
*.swp
*.swo

# Keep this trackable if present
!/wp-config-sample.php

# Local/dev plugins installed in Docker
/wp-content/plugins/advanced-custom-fields/
/wp-content/plugins/akismet/
/wp-content/plugins/hello.php

# Bundled default themes not used by this project
/wp-content/themes/twentytwentythree/
